# OpenDex configuration — copy to .env and fill in your values.
# install.sh will overwrite this automatically.

# Domain — Traefik routes radicale.<DOMAIN> and traefik.<DOMAIN>
DOMAIN=opendex.homelab.devasheeshmishra.com
ACME_EMAIL=

# Ports
HTTP_PORT=80
HTTPS_PORT=443

# UI
TRAEFIK_DASHBOARD=false
RADICALE_WEB_TYPE=none

# CardDAV (Radicale)
CARDDAV_USER=opendex
CARDDAV_PASSWORD=CHANGE_ME
