# Radicale configuration for OpenDex
# CardDAV/CalDAV server for contact and calendar sync
# Docs: https://radicale.org/master.html

[server]
# IPv4 only — Docker port mapping handles the rest
hosts = 0.0.0.0:5232
# 0 = unlimited connections (Radicale is low-traffic, single-user)
max_connections = 0
# 100 MB max request body (for large vCard photo imports)
max_content_length = 100000000
# 10 MB max single resource (individual vCard/iCal file)
max_resource_size = 10000000
timeout = 30

[auth]
# htpasswd file with bcrypt hashes, generated by install.sh
type = htpasswd
htpasswd_filename = /etc/radicale/users
htpasswd_encryption = bcrypt
htpasswd_cache = True
# 1s delay on failed auth to slow brute-force
delay = 1
# Cache successful logins for 15min, failed for 90s
cache_logins = True
cache_successful_logins_expiry = 15
cache_failed_logins_expiry = 90

[rights]
# Each user can only access their own collections
type = owner_only

[storage]
type = multifilesystem
filesystem_folder = /var/lib/radicale/collections
# Auto-create Contacts addressbook and Calendar for every new user on first login
predefined_collections = {"contacts": {"D:displayname": "Contacts", "tag": "VADDRESSBOOK"}, "calendar": {"C:supported-calendar-component-set": "VEVENT,VJOURNAL,VTODO", "D:displayname": "Calendar", "tag": "VCALENDAR"}}

[web]
# Disabled — no browser UI needed, access via CardDAV clients or OpenDex backend only
type = none

[logging]
level = info
mask_passwords = True
